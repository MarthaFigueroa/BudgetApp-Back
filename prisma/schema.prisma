// Prisma schema for Budget App
// Database: Neon (PostgreSQL serverless)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum CategoryType {
  housing
  utilities
  savings
  unexpected
  personal
  investments
  subscriptions
}

enum RecurringFrequency {
  weekly
  biweekly
  monthly
  quarterly
  yearly
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// A complete monthly budget snapshot
model MonthlyBudget {
  id         String   @id @default(cuid())
  month      Int      // 1–12
  year       Int
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Optional: tracks which base income template was applied
  baseIncomeTemplateMonth Int? @map("base_income_template_month")
  baseIncomeTemplateYear  Int? @map("base_income_template_year")

  incomeSources    IncomeSource[]
  categories       BudgetCategory[]

  @@unique([month, year])
  @@map("monthly_budgets")
}

/// A single income source within a monthly budget
model IncomeSource {
  id          String  @id @default(cuid())
  name        String
  amount      Float
  isRecurring Boolean @default(false) @map("is_recurring")

  budgetId String        @map("budget_id")
  budget   MonthlyBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@map("income_sources")
}

/// A spending category within a monthly budget (7 fixed types)
model BudgetCategory {
  id    String       @id @default(cuid())
  type  CategoryType
  name  String
  icon  String
  color String

  budgetId String        @map("budget_id")
  budget   MonthlyBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  items BudgetItem[]

  @@map("budget_categories")
}

/// An individual expense/line item within a category
model BudgetItem {
  id                 String              @id @default(cuid())
  name               String
  plannedAmount      Float               @map("planned_amount")
  actualAmount       Float               @default(0) @map("actual_amount")
  isPaid             Boolean             @default(false) @map("is_paid")
  dueDate            DateTime?           @map("due_date") @db.Date
  isRecurring        Boolean             @default(false) @map("is_recurring")
  recurringFrequency RecurringFrequency? @map("recurring_frequency")
  notes              String?
  createdAt          DateTime            @default(now()) @map("created_at")

  categoryId String         @map("category_id")
  category   BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("budget_items")
}

/// A versioned base income template (effective from a given month/year)
model BaseIncomeTemplate {
  id                 String   @id @default(cuid())
  effectiveFromMonth Int      @map("effective_from_month")
  effectiveFromYear  Int      @map("effective_from_year")
  createdAt          DateTime @default(now()) @map("created_at")

  sources BaseIncomeTemplateSource[]

  @@map("base_income_templates")
}

/// A single income source line within a base income template
model BaseIncomeTemplateSource {
  id          String  @id @default(cuid())
  name        String
  amount      Float
  isRecurring Boolean @default(false) @map("is_recurring")

  templateId String             @map("template_id")
  template   BaseIncomeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("base_income_template_sources")
}
