// Prisma schema for Budget App
// Database: Neon (PostgreSQL serverless)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum CategoryType {
  housing
  utilities
  savings
  unexpected
  personal
  investments
  subscriptions
}

enum RecurringFrequency {
  weekly
  biweekly
  monthly
  quarterly
  yearly
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// A complete monthly budget snapshot
model MonthlyBudget {
  id        String   @id @default(cuid())
  month     Int      // 1–12
  year      Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Which recurring-income template was applied when this budget was created
  templateId String?         @map("template_id")
  template   IncomeTemplate? @relation(fields: [templateId], references: [id])

  incomeSources IncomeSource[]
  items         BudgetItem[]

  @@unique([month, year])
  @@map("monthly_budgets")
}

/// Global reference table — 7 fixed category definitions, shared across all budgets
model Category {
  id    String       @id @default(cuid())
  type  CategoryType @unique
  name  String
  icon  String
  color String

  items BudgetItem[]

  @@map("categories")
}

/// A single income entry for one specific month.
/// May originate from a template (isFromTemplate=true) or be entered ad-hoc (isFromTemplate=false).
model IncomeSource {
  id   String @id @default(cuid())
  name String
  amount Float

  /// true  → was copied from a template item; will propagate to future months
  /// false → one-time income (bonus, gift, sale…); stays only in this month
  isFromTemplate Boolean @default(false) @map("is_from_template")

  budgetId String        @map("budget_id")
  budget   MonthlyBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  /// FK to the template item this was copied from (null for ad-hoc entries)
  templateItemId String?            @map("template_item_id")
  templateItem   IncomeTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)

  @@map("income_sources")
}

/// An individual expense/line item — belongs to a budget month AND a global category
model BudgetItem {
  id                 String              @id @default(cuid())
  name               String
  plannedAmount      Float               @map("planned_amount")
  actualAmount       Float               @default(0) @map("actual_amount")
  isPaid             Boolean             @default(false) @map("is_paid")
  dueDate            DateTime?           @map("due_date") @db.Date
  isRecurring        Boolean             @default(false) @map("is_recurring")
  recurringFrequency RecurringFrequency? @map("recurring_frequency")
  notes              String?
  createdAt          DateTime            @default(now()) @map("created_at")

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])

  budgetId String        @map("budget_id")
  budget   MonthlyBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@map("budget_items")
}

/// A named snapshot of recurring income sources.
/// When a new monthly budget is created the most recent template is applied automatically.
model IncomeTemplate {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  items   IncomeTemplateItem[]
  budgets MonthlyBudget[]

  @@map("income_templates")
}

/// One recurring income line inside a template (salary, dividends, etc.)
model IncomeTemplateItem {
  id                 String              @id @default(cuid())
  name               String
  amount             Float
  recurringFrequency RecurringFrequency? @map("recurring_frequency")

  templateId String         @map("template_id")
  template   IncomeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  /// All monthly income sources copied from this item
  sources IncomeSource[]

  @@map("income_template_items")
}
